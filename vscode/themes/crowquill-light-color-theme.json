  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "comment.block",
        "comment.line"
      ],
      "settings": {
        "foreground": "#9E9E9E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Documentation / JSDoc",
      "scope": [
        "comment.block.documentation",
        "comment.block.documentation storage.type",
        "keyword.other.documentation"
      ],
      "settings": {
        "foreground": "#909090",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.template",
        "string.unquoted",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#6C6C6C"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape",
        "constant.character.string.escape",
        "string.regexp constant.character.escape"
      ],
      "settings": {
        "foreground": "#2A2A2A"
      }
    },
    {
      "name": "Regular Expression",
      "scope": [
        "string.regexp",
        "punctuation.definition.character-class"
      ],
      "settings": {
        "foreground": "#5C5C5C"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.decimal"
      ],
      "settings": {
        "foreground": "#2A2A2A"
      }
    },
    {
      "name": "Boolean / Null / Language Constant",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan",
        "constant.language.infinity"
      ],
      "settings": {
        "foreground": "#2A2A2A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constant / Enum member",
      "scope": [
        "constant.other",
        "constant.other.caps",
        "variable.other.constant",
        "constant.character"
      ],
      "settings": {
        "foreground": "#2A2A2A"
      }
    },
    {
      "name": "Keyword (SIGNATURE — darkest, bold, underline)",
      "scope": [
        "keyword",
        "keyword.other",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.operator.delete",
        "keyword.operator.instanceof",
        "keyword.operator.typeof",
        "keyword.operator.void"
      ],
      "settings": {
        "foreground": "#000000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Flow Keyword (SIGNATURE — darkest, bold, underline)",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.return",
        "keyword.control.trycatch",
        "keyword.control.exception"
      ],
      "settings": {
        "foreground": "#000000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage (SIGNATURE — darkest, bold, underline)",
      "scope": [
        "storage",
        "storage.type",
        "storage.type.function",
        "storage.type.class",
        "storage.type.enum",
        "storage.type.interface",
        "storage.type.namespace",
        "storage.modifier",
        "storage.modifier.async",
        "storage.modifier.static",
        "keyword.declaration"
      ],
      "settings": {
        "foreground": "#000000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator (BRIGHT — lit delimiter, no bold/underline)",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.bitwise",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Function / Method Definition",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#141414"
      }
    },
    {
      "name": "Function Call",
      "scope": [
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#141414"
      }
    },
    {
      "name": "Macro / Preprocessor",
      "scope": [
        "entity.name.function.preprocessor",
        "meta.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#3A3A3A"
      }
    },
    {
      "name": "Type / Class / Interface",
      "scope": [
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#3A3A3A"
      }
    },
    {
      "name": "Primitive / Built-in Type",
      "scope": [
        "support.type.primitive",
        "storage.type.built-in",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#3A3A3A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Namespace / Module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#3A3A3A"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "meta.definition.variable variable.other"
      ],
      "settings": {
        "foreground": "#444444"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#5C5C5C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object Property / Key",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#3A3A3A"
      }
    },
    {
      "name": "Language Variable (this / self / super)",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super",
        "keyword.other.this"
      ],
      "settings": {
        "foreground": "#2A2A2A",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Built-in / Global (console, window, etc.)",
      "scope": [
        "support.variable",
        "support.constant",
        "variable.other.global"
      ],
      "settings": {
        "foreground": "#3A3A3A"
      }
    },
    {
      "name": "Punctuation / Brackets / Delimiters (BRIGHT — lit, no bold/underline)",
      "scope": [
        "punctuation",
        "punctuation.definition.block",
        "punctuation.definition.bracket",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "punctuation.section",
        "meta.brace",
        "meta.brace.round",
        "meta.brace.square",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Punctuation Accessor / Delimiter (BRIGHT — lit, no bold/underline)",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.key-value",
        "punctuation.separator.dictionary.key-value"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator",
        "storage.type.annotation",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#3A3A3A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML / XML / JSX Tag",
      "scope": [
        "entity.name.tag",
        "entity.name.tag.html",
        "entity.name.tag.xml",
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#000000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML / XML Attribute",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id"
      ],
      "settings": {
        "foreground": "#3A3A3A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS Property",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#3A3A3A"
      }
    },
    {
      "name": "CSS Value / Unit",
      "scope": [
        "support.constant.property-value.css",
        "keyword.other.unit.css",
        "constant.numeric.css"
      ],
      "settings": {
        "foreground": "#2A2A2A"
      }
    },
    {
      "name": "CSS Selector",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#3A3A3A"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#000000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#141414",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#3A3A3A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#141414"
      }
    },
    {
      "name": "Markdown Inline Code / Quote",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#6C6C6C"
      }
    },
    {
      "name": "Markdown Quote",
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#6C6C6C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSON Key",
      "scope": [
        "support.type.property-name.json",
        "meta.structure.dictionary.key.json"
      ],
      "settings": {
        "foreground": "#3A3A3A"
      }
    },
    {
      "name": "Invalid / Error",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#141414",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Invalid Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#6C6C6C",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": ["markup.inserted", "meta.diff.header.to-file"],
      "settings": {
        "foreground": "#3C3C3C"
      }
    },
    {
      "name": "Diff Deleted",
      "scope": ["markup.deleted", "meta.diff.header.from-file"],
      "settings": {
        "foreground": "#9E9E9E"
      }
    },
    {
      "name": "Diff Changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#6C6C6C"
      }
    }
  ],
  "semanticTokenColors": {
    "keyword": {
      "foreground": "#000000",
      "bold": true
    },
    "keyword.controlFlow": {
      "foreground": "#000000",
      "bold": true
    },
    "modifier": {
      "foreground": "#000000",
      "bold": true
    },
    "*.declaration": {
      "bold": true
    },
    "comment": {
      "foreground": "#9E9E9E",
      "italic": true
    },
    "string": "#6C6C6C",
    "number": "#2A2A2A",
    "regexp": "#5C5C5C",
    "operator": "#000000",
    "function": "#141414",
    "function.declaration": {
      "foreground": "#141414",
      "bold": true
    },
    "method": "#141414",
    "macro": "#3A3A3A",
    "type": "#3A3A3A",
    "type.declaration": {
      "foreground": "#3A3A3A",
      "bold": true
    },
    "class": "#3A3A3A",
    "interface": "#3A3A3A",
    "enum": "#3A3A3A",
    "enumMember": "#2A2A2A",
    "struct": "#3A3A3A",
    "typeParameter": {
      "foreground": "#3A3A3A",
      "italic": true
    },
    "namespace": "#3A3A3A",
    "variable": "#444444",
    "variable.readonly": "#2A2A2A",
    "variable.constant": "#2A2A2A",
    "property": "#3A3A3A",
    "property.readonly": "#3A3A3A",
    "parameter": {
      "foreground": "#5C5C5C",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#2A2A2A",
      "italic": true,
      "bold": true
    },
    "builtinConstant": {
      "foreground": "#2A2A2A",
      "bold": true
    },
    "decorator": {
      "foreground": "#3A3A3A",
      "italic": true
    },
    "label": "#6C6C6C"
  }
}
