  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "comment.block",
        "comment.line"
      ],
      "settings": {
        "foreground": "#565656",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Documentation / JSDoc",
      "scope": [
        "comment.block.documentation",
        "comment.block.documentation storage.type",
        "keyword.other.documentation"
      ],
      "settings": {
        "foreground": "#606060",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.template",
        "string.unquoted",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#8C8C8C"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape",
        "constant.character.string.escape",
        "string.regexp constant.character.escape"
      ],
      "settings": {
        "foreground": "#B4B4B4"
      }
    },
    {
      "name": "Regular Expression",
      "scope": [
        "string.regexp",
        "punctuation.definition.character-class"
      ],
      "settings": {
        "foreground": "#A0A0A0"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.decimal"
      ],
      "settings": {
        "foreground": "#D2D2D2"
      }
    },
    {
      "name": "Boolean / Null / Language Constant",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan",
        "constant.language.infinity"
      ],
      "settings": {
        "foreground": "#D2D2D2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constant / Enum member",
      "scope": [
        "constant.other",
        "constant.other.caps",
        "variable.other.constant",
        "constant.character"
      ],
      "settings": {
        "foreground": "#D2D2D2"
      }
    },
    {
      "name": "Keyword (SIGNATURE — brightest, bold, underline)",
      "scope": [
        "keyword",
        "keyword.other",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.operator.delete",
        "keyword.operator.instanceof",
        "keyword.operator.typeof",
        "keyword.operator.void"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Flow Keyword (SIGNATURE — brightest, bold, underline)",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.return",
        "keyword.control.trycatch",
        "keyword.control.exception"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage (SIGNATURE — brightest, bold, underline)",
      "scope": [
        "storage",
        "storage.type",
        "storage.type.function",
        "storage.type.class",
        "storage.type.enum",
        "storage.type.interface",
        "storage.type.namespace",
        "storage.modifier",
        "storage.modifier.async",
        "storage.modifier.static",
        "keyword.declaration"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator (BRIGHT — lit delimiter, no bold/underline)",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.bitwise",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Function / Method Definition",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#EAEAEA"
      }
    },
    {
      "name": "Function Call",
      "scope": [
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#EAEAEA"
      }
    },
    {
      "name": "Macro / Preprocessor",
      "scope": [
        "entity.name.function.preprocessor",
        "meta.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#C6C6C6"
      }
    },
    {
      "name": "Type / Class / Interface",
      "scope": [
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#C6C6C6"
      }
    },
    {
      "name": "Primitive / Built-in Type",
      "scope": [
        "support.type.primitive",
        "storage.type.built-in",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#C6C6C6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Namespace / Module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#C6C6C6"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "meta.definition.variable variable.other"
      ],
      "settings": {
        "foreground": "#B8B8B8"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#A0A0A0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object Property / Key",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#C6C6C6"
      }
    },
    {
      "name": "Language Variable (this / self / super)",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super",
        "keyword.other.this"
      ],
      "settings": {
        "foreground": "#D2D2D2",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Built-in / Global (console, window, etc.)",
      "scope": [
        "support.variable",
        "support.constant",
        "variable.other.global"
      ],
      "settings": {
        "foreground": "#C6C6C6"
      }
    },
    {
      "name": "Punctuation / Brackets / Delimiters (BRIGHT — lit, no bold/underline)",
      "scope": [
        "punctuation",
        "punctuation.definition.block",
        "punctuation.definition.bracket",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "punctuation.section",
        "meta.brace",
        "meta.brace.round",
        "meta.brace.square",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Punctuation Accessor / Delimiter (BRIGHT — lit, no bold/underline)",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.key-value",
        "punctuation.separator.dictionary.key-value"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator",
        "storage.type.annotation",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#C6C6C6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML / XML / JSX Tag",
      "scope": [
        "entity.name.tag",
        "entity.name.tag.html",
        "entity.name.tag.xml",
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML / XML Attribute",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id"
      ],
      "settings": {
        "foreground": "#C6C6C6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS Property",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#C6C6C6"
      }
    },
    {
      "name": "CSS Value / Unit",
      "scope": [
        "support.constant.property-value.css",
        "keyword.other.unit.css",
        "constant.numeric.css"
      ],
      "settings": {
        "foreground": "#D2D2D2"
      }
    },
    {
      "name": "CSS Selector",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#C6C6C6"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#EAEAEA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#C6C6C6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#EAEAEA"
      }
    },
    {
      "name": "Markdown Inline Code / Quote",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#8C8C8C"
      }
    },
    {
      "name": "Markdown Quote",
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#8C8C8C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSON Key",
      "scope": [
        "support.type.property-name.json",
        "meta.structure.dictionary.key.json"
      ],
      "settings": {
        "foreground": "#C6C6C6"
      }
    },
    {
      "name": "Invalid / Error",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#EAEAEA",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Invalid Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#8C8C8C",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": ["markup.inserted", "meta.diff.header.to-file"],
      "settings": {
        "foreground": "#B4B4B4"
      }
    },
    {
      "name": "Diff Deleted",
      "scope": ["markup.deleted", "meta.diff.header.from-file"],
      "settings": {
        "foreground": "#565656"
      }
    },
    {
      "name": "Diff Changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#8C8C8C"
      }
    }
  ],
  "semanticTokenColors": {
    "keyword": {
      "foreground": "#FFFFFF",
      "bold": true
    },
    "keyword.controlFlow": {
      "foreground": "#FFFFFF",
      "bold": true
    },
    "modifier": {
      "foreground": "#FFFFFF",
      "bold": true
    },
    "*.declaration": {
      "bold": true
    },
    "comment": {
      "foreground": "#565656",
      "italic": true
    },
    "string": "#8C8C8C",
    "number": "#D2D2D2",
    "regexp": "#A0A0A0",
    "operator": "#FFFFFF",
    "function": "#EAEAEA",
    "function.declaration": {
      "foreground": "#EAEAEA",
      "bold": true
    },
    "method": "#EAEAEA",
    "macro": "#C6C6C6",
    "type": "#C6C6C6",
    "type.declaration": {
      "foreground": "#C6C6C6",
      "bold": true
    },
    "class": "#C6C6C6",
    "interface": "#C6C6C6",
    "enum": "#C6C6C6",
    "enumMember": "#D2D2D2",
    "struct": "#C6C6C6",
    "typeParameter": {
      "foreground": "#C6C6C6",
      "italic": true
    },
    "namespace": "#C6C6C6",
    "variable": "#B8B8B8",
    "variable.readonly": "#D2D2D2",
    "variable.constant": "#D2D2D2",
    "property": "#C6C6C6",
    "property.readonly": "#C6C6C6",
    "parameter": {
      "foreground": "#A0A0A0",
      "italic": true
    },
    "selfKeyword": {
      "foreground": "#D2D2D2",
      "italic": true,
      "bold": true
    },
    "builtinConstant": {
      "foreground": "#D2D2D2",
      "bold": true
    },
    "decorator": {
      "foreground": "#C6C6C6",
      "italic": true
    },
    "label": "#8C8C8C"
  }
}
