{
  "name": "crowquill-theme",
  "displayName": "Crowquill Ink",
  "description": "Strict monochrome (black & white / grayscale) ink theme tuned for the Crowquill Mono font. Language keywords are the single brightest (dark) / darkest (light) element, rendered BOLD with a signature underline, while everything else stays a dimmer shade of gray. Ships two variants: Ink Dark and Ink Light.",
  "version": "0.2.0",
  "publisher": "andersonflima",
  "license": "MIT",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "monochrome",
    "grayscale",
    "black and white",
    "color-theme",
    "crowquill",
    "crowquill mono",
    "bold keywords"
  ],
  "galleryBanner": {
    "color": "#0A0A0A",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/andersonflima/crowquill-mono.git",
    "directory": "editor/vscode"
  },
  "contributes": {
    "themes": [
      {
        "label": "Crowquill Ink Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/crowquill-dark-color-theme.json"
      },
      {
        "label": "Crowquill Ink Light",
        "uiTheme": "vs",
        "path": "./themes/crowquill-light-color-theme.json"
      }
    ]
  }
}
